# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# Paste the entire contents of your service account JSON key file (minified to one line)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART/edit
SHEET_ID=your_sheet_id_here

# Gmail address used to send the notification
GMAIL_USER=you@gmail.com

# 16-character Gmail App Password (Google Account → Security → App Passwords)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email address that receives the done notification
RECIPIENT_EMAIL=you@gmail.com
